#######################################
# GLOBAL POSTGRES (docker-compose)
#######################################
POSTGRES_USER=choose-a-username
POSTGRES_PASSWORD=choose-a-secure-password
POSTGRES_DB=choose-a-database-name

#######################################
# API CONFIG
#######################################
API_NAME=Cyber Dashboard API
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=INFO

DATABASE_URL=postgresql://choose-a-username:choose-a-secure-password@db:5432/choose-a-database-name

#######################################
# SCHEDULER CONFIG
#######################################
SCHEDULER_DB_HOST=db
SCHEDULER_DB_PORT=5432
SCHEDULER_DB_NAME=choose-a-database-name
SCHEDULER_DB_USER=choose-a-username
SCHEDULER_DB_PASSWORD=choose-a-secure-password

LIMIT_REQUEST_PER_DAY=24
LOG_LEVEL=INFO
HTTP_TIMEOUT_SECONDS=10
POLL_SAFETY_WINDOW_SECONDS=300

#######################################
# OGO CONFIG
#######################################
OGO_BASE_URL=https://ogo.example.com
OGO_USERNAME=replace-me
OGO_API_KEY=replace-me
OGO_SITE_NAME_OR_ID=replace-me
OGO_JOURNAL_PAGE_SIZE=100

#######################################
# SERENICITY CONFIG
#######################################
SERENICITY_BASE_URL=https://api.example.com/serenicity
SERENICITY_API_KEY=replace-me

#######################################
# CORRELATOR CONFIG
#######################################
CORRELATOR_DB_HOST=db
CORRELATOR_DB_PORT=5432
CORRELATOR_DB_NAME=choose-a-database-name
CORRELATOR_DB_USER=choose-a-username
CORRELATOR_DB_PASSWORD=choose-a-secure-password

CORRELATOR_BATCH_SIZE=500
CORRELATOR_POLL_INTERVAL_SECONDS=10
CORRELATOR_LOG_LEVEL=INFO
CORRELATOR_COMPUTE_AVERAGE_PROCESSING_TIME=false